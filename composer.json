{
  "name":"insight-lpr/laravel-clickhouse-eloquent",
  "version" : "0.2.0.0",
  "description":"ClickHouse integration for Laravel with Eloquent-like ORM and query builder",
  "keywords":[
    "php",
    "laravel",
    "clickhouse"
  ],
  "homepage":"https://github.com/insight-lpr/laravel-clickhouse-eloquent",
  "type":"library",
  "minimum-stability": "stable",
  "license":"MIT",
  "authors":[
    {
      "name":"Akbarali",
      "email":"github@akbarali.uz",
      "homepage":"https://github.com/insight-lpr"
    }
  ],
  "require":{
    "php":">=8.1",
    "ext-curl":"*",
    "ext-json":"*",
    "illuminate/support":">=9",
    "illuminate/database":">=9"
  },
  "require-dev":{
    "laravel/framework":">=9",
    "phpunit/phpunit":"^9"
  },
  "suggest":{
  },
  "autoload":{
    "psr-4":{
      "LaravelClickhouseEloquent\\":"src/"
    }
  },
  "autoload-dev":{
